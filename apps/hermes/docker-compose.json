{
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "schemaVersion": 2,
  "services": [
    {
      "name": "hermes",
      "image": "nousresearch/hermes-agent:v2026.6.5",
      "isMain": true,
      "command": "gateway run",
      "internalPort": 9119,
      "environment": [
        {
          "key": "HERMES_DASHBOARD",
          "value": "1"
        },
        {
          "key": "HERMES_DASHBOARD_INSECURE",
          "value": "1"
        },
        {
          "key": "HERMES_DASHBOARD_HOST",
          "value": "0.0.0.0"
        },
        {
          "key": "HERMES_DASHBOARD_PORT",
          "value": "9119"
        },
        {
          "key": "ANTHROPIC_API_KEY",
          "value": "${ANTHROPIC_API_KEY}"
        },
        {
          "key": "OPENAI_API_KEY",
          "value": "${OPENAI_API_KEY}"
        },
        {
          "key": "OPENROUTER_API_KEY",
          "value": "${OPENROUTER_API_KEY}"
        }
      ],
      "addPorts": [
        {
          "containerPort": 8642,
          "hostPort": 8642,
          "tcp": true
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/hermes",
          "containerPath": "/opt/data"
        }
      ],
      "healthCheck": {
        "test": "wget --no-verbose --tries=1 --spider http://localhost:9119/ || exit 1",
        "interval": "30s",
        "timeout": "5s",
        "retries": 5,
        "startPeriod": "30s"
      }
    }
  ]
}
