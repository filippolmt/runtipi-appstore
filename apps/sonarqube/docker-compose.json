{
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "schemaVersion": 2,
  "services": [
    {
      "name": "sonarqube",
      "image": "mc1arke/sonarqube-with-community-branch-plugin:26.5.0.122743-community",
      "isMain": true,
      "internalPort": 9000,
      "dependsOn": {
        "sonarqube-db": {
          "condition": "service_healthy"
        }
      },
      "environment": [
        {
          "key": "SONAR_JDBC_URL",
          "value": "jdbc:postgresql://sonarqube-db:5432/sonar"
        },
        {
          "key": "SONAR_JDBC_USERNAME",
          "value": "sonar"
        },
        {
          "key": "SONAR_JDBC_PASSWORD",
          "value": "${DB_PASSWORD}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/sonarqube_data",
          "containerPath": "/opt/sonarqube/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/sonarqube_logs",
          "containerPath": "/opt/sonarqube/logs"
        }
      ]
    },
    {
      "name": "sonarqube-db",
      "image": "postgres:17-alpine",
      "environment": [
        {
          "key": "POSTGRES_USER",
          "value": "sonar"
        },
        {
          "key": "POSTGRES_PASSWORD",
          "value": "${DB_PASSWORD}"
        },
        {
          "key": "POSTGRES_DB",
          "value": "sonar"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/postgres",
          "containerPath": "/var/lib/postgresql/data"
        }
      ],
      "healthCheck": {
        "test": "pg_isready -U sonar -d sonar",
        "interval": "10s",
        "timeout": "5s",
        "retries": 5,
        "startPeriod": "30s"
      }
    }
  ]
}
